# Web-app-specific ignores only. node_modules, coverage, *.tsbuildinfo,
# .env/.env.local, logs and OS cruft are covered by the repo-root .gitignore.

# next.js
/.next/
/out/

# vercel
.vercel

# generated by `next dev`/`next build`, never hand-edited
next-env.d.ts

# env files — the checked-in template is the one exception
.env*
!.env.local.example
