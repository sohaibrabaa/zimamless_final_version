{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // The base config targets Node/CommonJS for the NestJS API. Everything
    // below re-points it at the browser/bundler world Next.js compiles for.
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "noEmit": true,
    "declaration": false,
    "sourceMap": false,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  // vitest.config.mts is excluded deliberately: Next and vitest each bundle
  // their own Vite (rolldown- vs rollup-based) and their plugin types are
  // mutually unassignable, so typechecking the test-runner config here fails
  // for reasons that have nothing to do with application code. vitest
  // typechecks it itself when it loads it.
  "exclude": ["node_modules", "vitest.config.mts", "vitest.live.config.mts"]
}
