# Copy to .env.local and fill in. Never commit real values.

# Ports: the API owns 3000 — the frozen contract's servers block names
# http://localhost:3000/v1 — so the web app runs on 3001 (see the --port flag
# in package.json). Both can then run at once, which the mock→live swap needs.

# Agent A's NestJS API. Only reachable once ENDPOINT_STATUS.md entries flip to "live".
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/v1

# "disabled" once every demo-path endpoint in lib/api/endpoint-status.ts is live.
# While enabled, the Supabase variables below may stay empty (placeholders are
# substituted); once disabled they are required and startup fails without them.
NEXT_PUBLIC_API_MOCKING=enabled

# Supabase Auth (registration/login run client-side against Supabase directly — PA-04).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
