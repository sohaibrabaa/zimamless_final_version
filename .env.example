# =====================================================================
# Zimmamless V3 — environment template
# =====================================================================
# Copy to .env and fill in. .env is gitignored and must never be committed.
# Full reference, including which value is safe where: docs/specs/ENVIRONMENTS.md
#
# SECURITY: SUPABASE_SERVICE_ROLE_KEY and DATABASE_URL are server-only.
# They bypass RLS. They must never appear in /apps/web, in any NEXT_PUBLIC_*
# variable, in a client bundle, or in a log line.
# =====================================================================

# --- Database ---------------------------------------------------------
# Supabase → Project Settings → Database → Connection string.
# Use SESSION mode (port 5432) or the direct connection for migrations;
# the transaction pooler (port 6543) cannot run DDL.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Supabase ---------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
# Verifies incoming JWTs. Safe to expose to the browser (Agent B uses it).
SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS. Never leaves the API process.
SUPABASE_SERVICE_ROLE_KEY=
# Legacy HS256 projects only: Project Settings → API → JWT Secret.
# Leave blank for projects using asymmetric (ES256/RS256) signing keys —
# the API then verifies against the project JWKS automatically.
SUPABASE_JWT_SECRET=

# --- API --------------------------------------------------------------
NODE_ENV=development
# The API owns 3000 because the frozen contract's servers block names it.
# The web app therefore runs on 3001 (apps/web/package.json passes --port).
PORT=3000
# Contract servers block: http://localhost:3000/v1
API_GLOBAL_PREFIX=v1
LOG_LEVEL=debug
# Comma-separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:3001

# --- ML service -------------------------------------------------------
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT_MS=5000

# --- Demo time machine ------------------------------------------------
# Server-side guard for ZM-DEMO-003/004. MUST be false in production:
# /demo/time-travel returns 404 unless this is true AND the
# demo_time_machine_enabled platform setting is true.
DEMO_TIME_MACHINE_ENABLED=false

# Auth-context cache TTL in ms (see auth.service.ts). 0/unset = disabled.
# Demo convenience only: a revoked membership can outlive itself by the TTL.
AUTH_CONTEXT_CACHE_MS=0
